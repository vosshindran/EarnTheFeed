{
  "manifest_version": 3,
  "name": "Earn The Feed",
  "version": "1.0.0",
  "description": "Lock Instagram and earn your feed by solving a puzzle.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}